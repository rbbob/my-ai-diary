# Production Server Configuration
PORT=3002
NODE_ENV=production

# OpenAI Configuration
OPENAI_API_KEY=your-production-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Rate Limiting
RATE_LIMIT_MAX=50
RATE_LIMIT_WINDOW=15

# CORS Configuration
CORS_ORIGIN=https://your-domain.com

# Security
TRUST_PROXY=true